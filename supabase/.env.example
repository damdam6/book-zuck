# Edge Function 서버 시크릿 템플릿.
# 이 값들은 브라우저에 노출되면 안 된다 — 루트 .env(VITE_*)에 넣지 말 것.
#
# 등록 방법(둘 중 하나):
#   (A) 대시보드: Supabase → Edge Functions → Secrets 에 아래 KEY/VALUE를 하나씩 입력
#   (B) CLI:      이 파일을 supabase/.env 로 복사해 값 채운 뒤
#                 supabase secrets set --env-file supabase/.env
#
# 주의: SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY 는
#       함수 런타임에 자동 주입되므로 여기에 등록할 필요 없다.

# --- RTZR / VITO STT ---
RTZR_CLIENT_ID=
RTZR_CLIENT_SECRET=
RTZR_BASE_URL=https://openapi.vito.ai

# --- Cloudflare R2 (S3 호환) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=audio-uploads

# --- 폴링 cron 보호용 (Vault의 cron_secret과 동일한 값) ---
CRON_SECRET=

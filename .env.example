# 브라우저(SPA)에 노출되는 변수만 VITE_ 접두를 쓴다.
# RTZR / R2 자격증명은 절대 여기에 두지 말 것 — Edge Function 시크릿으로만 관리한다.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# 서버 측(Edge Function) 시크릿은 supabase secrets로 등록한다. 아래는 참고용 목록:
#   RTZR_CLIENT_ID, RTZR_CLIENT_SECRET, RTZR_BASE_URL(선택)
#   R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET
#   CRON_SECRET
# 자세한 절차는 supabase/README.md 참고.

# 브라우저(SPA)에 노출되는 변수만 VITE_ 접두를 쓴다.
# RTZR / R2 자격증명은 절대 여기에 두지 말 것 — Edge Function 시크릿으로만 관리한다.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# 서버 측(Edge Function) 시크릿은 여기 두지 말고 supabase/.env.example 템플릿을 사용한다.
# (Supabase → Edge Functions → Secrets 에 등록. 자세한 절차는 supabase/README.md)
